{
  "name": "sentient-mesh",
  "version": "1.1.5",
  "description": "Customizable 3D sentient wireframe mesh and shader for React Three Fiber",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "threejs",
    "react-three-fiber",
    "shader",
    "wireframe",
    "r3f",
    "3d"
  ],
  "author": "munheda",
  "repository": {
    "type": "git",
    "url": "https://github.com/lealemkinfe/sentient-mesh.git"
  },
  "homepage": "https://github.com/lealemkinfe/sentient-mesh#readme",
  "bugs": {
    "url": "https://github.com/lealemkinfe/sentient-mesh/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "@react-three/drei": "^9.0.0 || ^10.0.0",
    "@react-three/fiber": "^8.0.0 || ^9.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.150.0"
  },
  "dependencies": {
    "three-stdlib": "^2.30.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/three": "^0.184.0",
    "tsup": "^8.0.2",
    "typescript": "^5.0.0"
  }
}
